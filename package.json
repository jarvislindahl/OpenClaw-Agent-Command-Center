{
    "name": "openclaw-agent-command-center",
    "description": "Comprehensive agent management dashboard plugin for OpenClaw",
    "version": "1.0.0",
    "type": "module",
    "main": "./dist/server/index.js",
    "exports": {
        ".": "./dist/server/index.js"
    },
    "scripts": {
        "build": "tsc",
        "dev": "tsc --watch",
        "test": "vitest run",
        "typecheck": "tsc --noEmit"
    },
    "openclaw": {
        "extensions": [
            "./dist/server/index.js"
        ],
        "activation": {
            "onStartup": true
        },
        "contracts": {
            "tools": [
                "run_task_flow"
            ]
        },
        "tools": [
            {
                "name": "run_task_flow",
                "description": "Orchestrate a multi-step task flow across agents. Actions: run (start flow), step_complete (advance), resume (after approval gate)."
            }
        ]
    },
    "peerDependencies": {
        "openclaw": "*"
    },
    "devDependencies": {
        "@types/node": "^22.0.0",
        "fast-check": "^4.6.0",
        "typescript": "^5.7.0",
        "vitest": "^3.0.0"
    },
    "license": "MIT"
}
